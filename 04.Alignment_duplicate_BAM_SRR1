#!/bin/bash
#SBATCH --job-name=bwa_mem
#SBATCH --account=project_2000886
#SBATCH --partition=small
#SBATCH --time=48:00:00
#SBATCH --cpus-per-task=8
#SBATCH --mem=32G
#SBATCH --array=1-3
#SBATCH --output=logs/bwa_%A_%a.out
#SBATCH --error=logs/bwa_%A_%a.err

module load biokit

# Select sample based on array index
SAMPLE=$(sed -n "${SLURM_ARRAY_TASK_ID}p" /scratch/project_2000886/Hoedric/GWAS_2025/aligned_reads/BWA/missing_samples.txt)

ref="/scratch/project_2000886/Elisa/reseq/GCA_024166365.1_mEleMax1_primary_haplotype_genomic.fa"
fastq_dir="/scratch/project_2000886/Hoedric/GWAS_2025/data/GENOTYPE/Fastq/${SAMPLE}"
outdir="/scratch/project_2000886/Hoedric/GWAS_2025/aligned_reads/BWA"

mkdir -p "$outdir"

bwa mem -t 8 -R "@RG\tID:${SAMPLE}\tPL:ILLUMINA\tSM:${SAMPLE}" \
    "$ref" \
    "${fastq_dir}/${SAMPLE}_1.fastq.gz" \
    "${fastq_dir}/${SAMPLE}_2.fastq.gz" \
| samtools sort -@ 8 -o "${outdir}/${SAMPLE}.sorted.bam"
