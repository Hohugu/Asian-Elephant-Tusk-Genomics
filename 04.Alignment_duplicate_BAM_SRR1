#!/bin/bash
#SBATCH --job-name=04.Alignment_Duplicates
#SBATCH --account=project_2000886
#SBATCH --partition=small
#SBATCH --cpus-per-task=16
#SBATCH --mem=32G
#SBATCH --time=24:00:00
#SBATCH --output=logs/%x_%j.out
#SBATCH --error=logs/%x_%j.err

module load biokit
module load gatk

ref="/scratch/project_2000886/Elisa/reseq/GCA_024166365.1_mEleMax1_primary_haplotype_genomic.fa"
data="/scratch/project_2000886/Hoedric/GWAS_2025/data/GENOTYPE/Fastq"
outdir="/scratch/project_2000886/Hoedric/GWAS_2025/aligned_reads/BWA"

mkdir -p $outdir
mkdir -p /scratch/$USER/tmp

# 1. Alignment + sorting
bwa mem -t 16 -R "@RG\tID:SRR25983372\tPL:ILLUMINA\tSM:SRR25983372" \
    $ref \
    $data/SRR25983372_1.fastq.gz \
    $data/SRR25983372_2.fastq.gz \
| samtools sort -@ 8 -o $outdir/SRR25983372.sorted.bam

# 2. Mark duplicates with GATK
gatk MarkDuplicatesSpark \
    -I $outdir/SRR25983372.sorted.bam \
    -O $outdir/SRR25983372_sorted_duplicates_reads.bam \
    --tmp-dir /scratch/$USER/tmp
