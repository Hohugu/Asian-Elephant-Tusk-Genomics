#!/bin/bash
#SBATCH --job-name=MarkDup_SRR
#SBATCH --account=project_2000886
#SBATCH --partition=small
#SBATCH --cpus-per-task=8
#SBATCH --mem=32G
#SBATCH --time=24:00:00
#SBATCH --output=logs/MarkDup_SRR_%A_%a.out
#SBATCH --error=logs/MarkDup_SRR_%A_%a.err
#SBATCH --array=11-28%2

set -euo pipefail

module load biokit
module load gatk

LIST="/scratch/project_2000886/Hoedric/GWAS_2025/data/PHENOTYPE/SRA_SRR_list.txt"
BAM_DIR="/scratch/project_2000886/Hoedric/GWAS_2025/aligned_reads/BWA"
TMP_BASE="/scratch/project_2000886/Hoedric/GWAS_2025/tmp_markdup"

mkdir -p "$TMP_BASE"

SAMPLE=$(sed -n "${SLURM_ARRAY_TASK_ID}p" "$LIST" | tr -d '[:space:]')

echo "=================================="
echo " MarkDuplicates for SRR"
echo " Sample: $SAMPLE"
echo " Task:   ${SLURM_ARRAY_TASK_ID}"
echo " Time:   $(date)"
echo "=================================="

IN_BAM="${BAM_DIR}/${SAMPLE}.sorted.bam"
OUT_BAM="${BAM_DIR}/${SAMPLE}_sorted_duplicates_reads.bam"
METRICS="${BAM_DIR}/${SAMPLE}_markdup_metrics.txt"
TMP_DIR="${TMP_BASE}/${SAMPLE}"
mkdir -p "$TMP_DIR"

# Check input
if [[ ! -f "$IN_BAM" ]]; then
    echo "Input BAM not found: $IN_BAM. Skipping."
    exit 0
fi

# Skip if output already exists (resume capability)
if [[ -f "$OUT_BAM" ]]; then
    echo "Output BAM already exists for $SAMPLE. Skipping."
    exit 0
fi

echo "Running GATK MarkDuplicates for $SAMPLE"
echo "Input BAM:  $IN_BAM"
echo "Output BAM: $OUT_BAM"
echo "Metrics:    $METRICS"
echo "Tmp dir:    $TMP_DIR"

gatk MarkDuplicates \
    -I "$IN_BAM" \
    -O "$OUT_BAM" \
    -M "$METRICS" \
    --TMP_DIR "$TMP_DIR" \
    --VALIDATION_STRINGENCY SILENT \
    --CREATE_INDEX true

echo "MarkDuplicates finished for $SAMPLE"

# Remove input BAM to save space
rm -f "$IN_BAM"
echo "Removed input BAM: $IN_BAM"

echo "Finished sample $SAMPLE at $(date)"
